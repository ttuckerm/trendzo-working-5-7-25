{
  "manifest_version": 3,
  "name": "ViralLab Telemetry",
  "version": "0.1.0",
  "description": "Lightweight stub to send first-hour telemetry to ViralLab backend.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ViralLab Telemetry"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}


