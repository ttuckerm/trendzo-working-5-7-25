# CleanCopy / Trendzo Environment Variables

# Database
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_supabase_service_key

# AI Services
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key

# Gemini AI (Required for Gemini 3 Pro Preview Analysis Component)
# Get your API key from: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=your_google_ai_api_key
# Alternative environment variable name (both work):
# GEMINI_API_KEY=your_gemini_api_key

# Whisper (Transcription)
OPENAI_API_KEY=your_openai_key_for_whisper

# Apify (Video Scraping)
APIFY_API_TOKEN=your_apify_token

# Cling AI (Video Generation)
CLING_API_KEY=your_cling_api_key

# Other Services
RESEND_API_KEY=your_resend_key
STRIPE_SECRET_KEY=your_stripe_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
