# =============================================================================
# TRENDZO ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env.local (development) or .env.production (production)
# =============================================================================

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Environment (development, production, staging)
NODE_ENV=production

# Application URL (used for redirects, webhooks, etc.)
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Admin Configuration
NEXT_PUBLIC_ADMIN_EMAIL=admin@yourdomain.com

# Security Settings
TESTING_MODE=false

# =============================================================================
# DATABASE CONFIGURATION (Supabase)
# =============================================================================

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# =============================================================================
# AUTHENTICATION
# =============================================================================

# NextAuth Configuration
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=your_nextauth_secret_at_least_32_chars

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# =============================================================================
# AI SERVICES
# =============================================================================

# OpenAI API (for content analysis)
OPENAI_API_KEY=sk-your_openai_api_key

# Anthropic Claude API (alternative to OpenAI)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# Hugging Face API (optional ML models)
HUGGING_FACE_API_KEY=hf_your_hugging_face_token

# =============================================================================
# DATA SCRAPING & EXTERNAL APIs
# =============================================================================

# Apify Configuration (for TikTok scraping)
APIFY_API_TOKEN=apify_api_your_token

# Apify Actor IDs (specific to your Apify setup)
APIFY_TRENDING_VIDEOS_ACTOR=GdWCkxzABDOZaHoVT
APIFY_FAST_API_ACTOR=uesAJWkuLhLgfPawS
APIFY_DATA_EXTRACTOR_ACTOR=BDiUQYh9HLNr7TZXQ
APIFY_COMMENTS_ACTOR=uTbyYiGkrEEEfKgfW
APIFY_HASHTAGS_ACTOR=JgXcWxmZRaVQMKxsV
APIFY_SOUNDS_ACTOR=qSFGDnFNZxSnCRYYo
APIFY_TRANSCRIPTS_ACTOR=aYG89mhUJqgsPeHaH

# =============================================================================
# VIDEO PROCESSING (Optional)
# =============================================================================

# Remotion for video generation
REMOTION_LAMBDA_REGION=us-east-1

# Shotstack for video editing
SHOTSTACK_API_KEY=your_shotstack_api_key

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================

# Logging Configuration
LOG_PREDICTIONS=true
LOG_LEVEL=info

# Performance Monitoring
METRICS_API_BASE=https://api.yourdomain.com/metrics

# =============================================================================
# GRAFANA MONITORING (Production)
# =============================================================================

# Grafana Admin Password
GRAFANA_ADMIN_PASSWORD=secure_admin_password_change_this

# =============================================================================
# REDIS CONFIGURATION (Production)
# =============================================================================

# Redis Connection (if using external Redis)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# =============================================================================
# SECURITY & RATE LIMITING
# =============================================================================

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Origins (comma-separated)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable specific features
ENABLE_BATCH_PROCESSING=true
ENABLE_REAL_TIME_PREDICTIONS=true
ENABLE_ADMIN_PANEL=true
ENABLE_API_DOCS=false

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================

# Container Configuration
CONTAINER_PORT=3000
HOSTNAME=0.0.0.0

# Health Check Configuration
HEALTH_CHECK_TIMEOUT=30000
HEALTH_CHECK_INTERVAL=60000

# =============================================================================
# BACKUP & RECOVERY
# =============================================================================

# Database Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# Development specific settings (only used when NODE_ENV=development)
CHOKIDAR_USEPOLLING=true
NEXT_TELEMETRY_DISABLED=1

# Mock data for development
USE_MOCK_DATA=false