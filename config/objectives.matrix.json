				"metrics": [ { "source": "api:/api/rd/discoveries", "path": "count", "op": ">=", "value": 1 } ],
				"timing": []
			},
			"logic": "AND"
		},
		{
			"id": "process_intelligence_layer",
			"title": "Process Intelligence Layer",
			"route": "/admin/operations-center",
			"anchor": "#process-intel",
			"checks": {
				"dom": [ { "selector": "[data-testid='process-journeys']", "exists": true } ],
				"metrics": [ { "source": "api:/api/process/journeys", "path": "bottlenecks_found", "op": ">=", "value": 1 } ],
				"timing": []
			},
			"logic": "AND"
		},
		{
			"id": "marketing_inception",
			"title": "Marketing Inception",
			"route": "/admin/operations-center",
			"anchor": "#marketing-inception",
			"checks": {
				"dom": [ { "selector": "[data-testid='marketing-inception']", "exists": true } ],
				"metrics": [ { "source": "api:/api/marketing/summary", "path": "promo_videos", "op": ">=", "value": 1 } ],
				"timing": []
			},
			"logic": "AND"
		},
		{
			"id": "defensible_moat",
			"title": "Defensible Moat",
			"route": "/admin/operations-center",
			"anchor": "#moat",
			"checks": {
				"dom": [ { "selector": "[data-testid='moat-insights']", "exists": true } ],
				"metrics": [ { "source": "api:/api/moat/benchmarks", "path": "advantage_score", "op": ">=", "value": 1.0 } ],
				"timing": []
			},
			"logic": "AND"
		},
		{
			"id": "scale_from_zero",
			"title": "Scale from Zero",
			"route": "/admin/operations-center",
			"anchor": "#scale-zero",
			"checks": {
				"dom": [ { "selector": "[data-testid='scale-zero-panel']", "exists": true } ],
				"metrics": [ { "source": "api:/api/scale/status", "path": "active_accounts", "op": ">=", "value": 1 } ],
				"timing": []
