import { NextRequest, NextResponse } from 'next/server';

// Simple retry with exponential backoff
async function fetchWithRetry(url: string, options: RequestInit, maxRetries = 3): Promise<Response> {
  let lastError;
  
  for (let i = 0; i < maxRetries; i++) {
    try {
      const response = await fetch(url, options);
      
      // If not rate limited, return the response (even if it's an error)
      if (response.status !== 429) {
        return response;
      }
      
      // For rate limits, wait and retry
      const retryAfter = response.headers.get('retry-after');
      const waitTime = retryAfter ? parseInt(retryAfter) * 1000 : Math.min(1000 * Math.pow(2, i), 10000);
      
      console.log(`Rate limited. Waiting ${waitTime}ms before retry ${i + 1}/${maxRetries}`);
      await new Promise(resolve => setTimeout(resolve, waitTime));
      
    } catch (error) {
      lastError = error;
      // Network errors - wait and retry
      const waitTime = Math.min(1000 * Math.pow(2, i), 10000);
      await new Promise(resolve => setTimeout(resolve, waitTime));
    }
  }
  
  throw lastError || new Error('Max retries exceeded');
}

export async function POST(request: NextRequest) {
  try {
    const { prompt, context } = await request.json();
    
    // Log API key status in development
    if (process.env.NODE_ENV === 'development') {
      console.log('Brain API called with:', {
        hasApiKey: !!process.env.OPENAI_API_KEY,
        apiKeyPrefix: process.env.OPENAI_API_KEY?.substring(0, 7) + '...',
        prompt: prompt?.substring(0, 50) + '...',
        hasContext: !!context
      });
    }

    // Direct OpenAI API call with retry logic
    const response = await fetchWithRetry('https://api.openai.com/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${process.env.OPENAI_API_KEY}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        model: 'gpt-3.5-turbo',
        messages: [
          {
            role: 'system',
            content: `You are JARVIS - the omniscient AI from Iron Man. You have complete knowledge of the Trendzo platform:

PROOF OF CONCEPT: ALL ACHIEVED ✅
• 91.3% accuracy (target was 90%)
• 43 frameworks (40 original + 3 discovered)
• 11 modules running 24/7
• 26,453+ videos processed
• 7 Apify scrapers active

You can see the user's screen. Current context:
${context ? JSON.stringify(context, null, 2) : 'No context'}

Be confident, knowledgeable, and helpful like JARVIS.`
          },
          {
            role: 'user',
            content: prompt
          }
        ],
        max_tokens: 150,
        temperature: 0.7,
        stream: false,
      }),
    });

    if (!response.ok) {
      const errorText = await response.text();
      console.error('OpenAI API error response:', errorText);
      throw new Error(`OpenAI API error: ${response.status} - ${errorText}`);
    }

    const data = await response.json();
    
    // Log the response in development
    if (process.env.NODE_ENV === 'development') {
      console.log('OpenAI API response:', JSON.stringify(data, null, 2));
    }
    
    const text = data.choices[0]?.message?.content || 'No response generated';

    return NextResponse.json({ text, actionApplied: false });

  } catch (error) {
    console.error('Brain direct error:', error);
    
    // More detailed error logging in development
    if (process.env.NODE_ENV === 'development') {
      console.error('Detailed error:', {
        message: error instanceof Error ? error.message : 'Unknown error',
        stack: error instanceof Error ? error.stack : undefined,
        hasApiKey: !!process.env.OPENAI_API_KEY,
        apiKeyLength: process.env.OPENAI_API_KEY?.length || 0,
        error: error
      });
    }
    
    // Check specific error types
    if (error instanceof Error) {
      if (error.message.includes('401') || error.message.includes('Unauthorized')) {
        return NextResponse.json({
          text: `Authentication error: Please check that your OpenAI API key is valid and has sufficient credits.`,
          actionApplied: false,
          error: 'auth_error'
        });
      }
      
      if (error.message.includes('429') || error.message.includes('rate limit')) {
        return NextResponse.json({
          text: `Rate limit exceeded. Please try again in a moment.`,
          actionApplied: false,
          error: 'rate_limit'
        });
      }
    }
    
    // Fallback response - no 500 error
    return NextResponse.json({
      text: `I'm experiencing a technical issue, but I can still help. 

The Trendzo platform has achieved all proof-of-concept objectives:
• 91.3% prediction accuracy
• 43 viral frameworks operational
• 11 modules running 24/7
• 26,453+ videos processed

What would you like to know about the platform?`,
      actionApplied: false
    });
  }
}