'use client';

// FEAT-072: Admin Accuracy Validation Workflow
// 6-step validation pipeline to prove 80-90% pre-posting accuracy
// Created: 2025-10-23

import { useState, useEffect } from 'react';
import { Play, CheckCircle, AlertCircle, Activity, Database, Brain, Fingerprint, Target, TrendingUp, Filter, Upload, Settings, ChevronRight, Info, BarChart3, FileCheck, Zap, Shield } from 'lucide-react';

// Types
interface ValidationRun {
  id: number;
  name: string;
  niche: string;
  format: string;
  targetMetric: string;
  status: 'setup' | 'intake' | 'pattern_qa' | 'fingerprint' | 'predict' | 'validate' | 'complete';
  accuracy?: string;
  approved?: boolean;
  date?: string;
}

interface StepConfig {
  id: number;
  name: string;
  icon: any;
  color: string;
}

interface TabConfig {
  id: string;
  label: string;
  icon: any;
}

export default function TestingAccuracyPage() {
  const [activeTab, setActiveTab] = useState('experiments');
  const [currentStep, setCurrentStep] = useState(1);
  const [loading, setLoading] = useState(false);
  const [progress, setProgress] = useState({ current: 0, total: 0 });
  const [message, setMessage] = useState('');
  const [messageType, setMessageType] = useState<'success' | 'error' | 'info'>('info');

  // Workflow state
  const [currentRunId, setCurrentRunId] = useState<string | null>(null);
  const [cohortData, setCohortData] = useState<any>(null);
  const [validationResults, setValidationResults] = useState<any>(null);

  const steps: StepConfig[] = [
    { id: 1, name: 'Experiment Setup', icon: Settings, color: 'from-purple-500 to-pink-500' },
    { id: 2, name: 'Intake & Cohort', icon: Database, color: 'from-blue-500 to-purple-500' },
    { id: 3, name: 'Pattern QA', icon: Brain, color: 'from-purple-500 to-indigo-500' },
    { id: 4, name: 'Fingerprint Map', icon: Fingerprint, color: 'from-indigo-500 to-purple-500' },
    { id: 5, name: 'Pre-Post Predict', icon: Target, color: 'from-purple-500 to-cyan-500' },
    { id: 6, name: 'Validate & Decide', icon: Shield, color: 'from-green-500 to-emerald-500' }
  ];

  const tabs: TabConfig[] = [
    { id: 'experiments', label: 'Experiments', icon: Activity },
    { id: 'intake', label: 'Intake', icon: Upload },
    { id: 'patterns', label: 'Patterns', icon: Brain },
    { id: 'fingerprints', label: 'Fingerprints', icon: Fingerprint },
    { id: 'predict', label: 'Predict & Validate', icon: Target }
  ];

  const showToast = (msg: string, type: 'success' | 'error' | 'info' = 'info') => {
    setMessage(msg);
    setMessageType(type);
    setTimeout(() => setMessage(''), 5000);
  };

  const handleStepAction = async (stepId: number) => {
    setLoading(true);
    setProgress({ current: 0, total: 100 });

    try {
      if (stepId === 1) {
        // Step 1: Create Validation Run
        setProgress({ current: 30, total: 100 });
        const response = await fetch('/api/validation/create-run', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: `Quick Win Validation Run #${Date.now()}`,
            description: 'Testing 80-90% accuracy on fitness/weight loss niche',
            niche: 'Fitness/Weight Loss',
            video_format: '15-30s',
            account_size: '10K-100K',
            timeframe: 'Last 7 days',
            success_metric: 'DPS ≥ 80'
          })
        });
        const result = await response.json();

        if (!result.success) throw new Error(result.error);

        setCurrentRunId(result.run.id);
        setProgress({ current: 100, total: 100 });
        showToast("✅ Experiment configured! Constraints locked. Click 'Intake & Cohort' to start data collection.", 'success');

      } else if (stepId === 2 && currentRunId) {
        // Step 2: Build Cohort
        setProgress({ current: 30, total: 100 });
        const response = await fetch('/api/validation/build-cohort', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            run_id: currentRunId,
            language_filter: 'English Only',
            timeframe_filter: 'Last 7 Days',
            dedupe_method: 'By Video ID',
            dps_threshold: 80
          })
        });
        const result = await response.json();

        if (!result.success) throw new Error(result.error);

        setCohortData(result.cohort);
        setProgress({ current: 100, total: 100 });
        showToast(`✅ Cohort built! Scraped ${result.cohort.total_videos_scraped} videos, ${result.cohort.videos_passing_dps} passing DPS ≥ 80. Next: Pattern QA.`, 'success');

      } else if (stepId === 3 && currentRunId && cohortData) {
        // Step 3: Extract Patterns
        setProgress({ current: 30, total: 100 });
        const videoIds = [...cohortData.train_video_ids, ...cohortData.val_video_ids];
        const response = await fetch('/api/validation/extract-patterns', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            run_id: currentRunId,
            video_ids: videoIds.slice(0, 50) // Limit to first 50 for performance
          })
        });
        const result = await response.json();

        if (!result.success) throw new Error(result.error);

        setProgress({ current: 100, total: 100 });
        showToast(`✅ Patterns extracted! ${result.summary.total_patterns} patterns, ${result.summary.verified_count} verified. Next: Generate fingerprints.`, 'success');

      } else if (stepId === 4 && currentRunId && cohortData) {
        // Step 4: Generate Fingerprints
        setProgress({ current: 30, total: 100 });
        const videoIds = [...cohortData.train_video_ids, ...cohortData.val_video_ids];
        const response = await fetch('/api/validation/generate-fingerprints', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            run_id: currentRunId,
            video_ids: videoIds.slice(0, 50)
          })
        });
        const result = await response.json();

        if (!result.success) throw new Error(result.error);

        setProgress({ current: 100, total: 100 });
        showToast(`✅ Fingerprints computed! ${result.fingerprints.length} templates mapped. Next: Run predictions.`, 'success');

      } else if (stepId === 5 && currentRunId && cohortData) {
        // Step 5: Lock Predictions
        setProgress({ current: 30, total: 100 });
        const testVideoIds = cohortData.test_video_ids;
        const response = await fetch('/api/validation/lock-predictions', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            run_id: currentRunId,
            video_ids: testVideoIds
          })
        });
        const result = await response.json();

        if (!result.success) throw new Error(result.error);

        setProgress({ current: 100, total: 100 });
        showToast(`✅ Predictions complete! ${result.summary.green_count} Green, ${result.summary.yellow_count} Yellow, ${result.summary.red_count} Red. Next: Validate accuracy.`, 'success');

      } else if (stepId === 6 && currentRunId && cohortData) {
        // Step 6: Validate Accuracy
        setProgress({ current: 30, total: 100 });
        const testVideoIds = cohortData.test_video_ids;
        const response = await fetch('/api/validation/validate-accuracy', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            run_id: currentRunId,
            test_video_ids: testVideoIds
          })
        });
        const result = await response.json();

        if (!result.success) throw new Error(result.error);

        setValidationResults(result);
        setProgress({ current: 100, total: 100 });
        showToast(`✅ Validation complete! ${result.accuracy_metrics.overall_accuracy.toFixed(1)}% accuracy achieved. ${result.meets_target ? 'Target met!' : 'Below target.'}`, 'success');
      }

      // Prevent step counter from going beyond 6
      setCurrentStep(Math.min(stepId + 1, 6));
      setLoading(false);

    } catch (error: any) {
      console.error('[handleStepAction] Error:', error);
      setLoading(false);
      setProgress({ current: 0, total: 0 });
      showToast(`❌ Error: ${error.message}`, 'error');
    }
  };

  return (
    <div className="min-h-screen bg-gradient-to-br from-[#0F0A1E] to-[#1a0f2e] text-white">
      {/* Header */}
      <header className="border-b border-purple-500/30 backdrop-blur-xl bg-black/50">
        <div className="px-6 py-4">
          <div className="flex items-center justify-between">
            <div className="flex items-center gap-3">
              <div className="w-10 h-10 bg-gradient-to-br from-pink-500 to-purple-600 rounded-lg flex items-center justify-center font-bold text-white shadow-lg">
                TZ
              </div>
              <h1 className="text-2xl font-bold text-white">
                Accuracy Validation Admin
              </h1>
            </div>
            <div className="flex items-center gap-2 text-sm">
              <Shield className="w-4 h-4 text-green-400" />
              <span className="text-gray-300">Target: 80-90% Pre-Post Accuracy</span>
            </div>
          </div>
        </div>
      </header>

      {/* Toast Notification */}
      {message && (
        <div className={`fixed top-20 right-6 max-w-lg p-5 rounded-xl backdrop-blur-xl border-2 z-50 transition-all transform shadow-2xl ${
          messageType === 'success' ? 'bg-green-800/90 border-green-400 text-white' :
          messageType === 'error' ? 'bg-red-800/90 border-red-400 text-white' :
          'bg-blue-800/90 border-blue-400 text-white'
        }`}>
          <div className="flex items-start gap-3">
            {messageType === 'success' ? <CheckCircle className="w-6 h-6 mt-0.5 text-green-300" /> :
             messageType === 'error' ? <AlertCircle className="w-6 h-6 mt-0.5 text-red-300" /> :
             <Info className="w-6 h-6 mt-0.5 text-blue-300" />}
            <p className="text-base font-bold">{message}</p>
          </div>
        </div>
      )}

      {/* Progress Pipeline */}
      <div className="px-6 py-6 border-b border-purple-500/30 bg-black/30">
        <div className="flex items-center justify-between">
          {steps.map((step, index) => (
            <div key={step.id} className="flex-1 flex items-center">
              <div className="flex flex-col items-center flex-1">
                <button
                  onClick={() => step.id === currentStep && handleStepAction(step.id)}
                  disabled={step.id !== currentStep || loading}
                  className={`
                    w-12 h-12 rounded-xl flex items-center justify-center transition-all transform
                    ${step.id < currentStep ? 'bg-green-500 shadow-lg shadow-green-500/50' :
                      step.id === currentStep ? `bg-gradient-to-br ${step.color} shadow-xl shadow-purple-500/50` :
                      'bg-gray-700 border-2 border-gray-600'}
                    ${step.id === currentStep && !loading ? 'hover:scale-110 cursor-pointer' : ''}
                    ${loading && step.id === currentStep ? 'animate-pulse' : ''}
                  `}
                >
                  <step.icon className={`w-5 h-5 ${step.id <= currentStep ? 'text-white' : 'text-gray-400'}`} />
                </button>
                <span className={`mt-2 text-xs font-semibold ${step.id <= currentStep ? 'text-white' : 'text-gray-500'}`}>
                  {step.name}
                </span>
                {loading && step.id === currentStep && (
                  <span className="mt-1 text-xs text-purple-300 font-bold">
                    {progress.current}%
                  </span>
                )}
              </div>
              {index < steps.length - 1 && (
                <div className={`h-1 flex-1 mx-2 transition-all rounded-full ${
                  step.id < currentStep ? 'bg-green-500 shadow-lg shadow-green-500/50' : 'bg-gray-700'
                }`} />
              )}
            </div>
          ))}
        </div>
      </div>

      {/* Tabs */}
      <div className="px-6 pt-4 bg-black/40">
        <div className="flex gap-2 border-b-2 border-purple-500/50">
          {tabs.map(tab => (
            <button
              key={tab.id}
              onClick={() => setActiveTab(tab.id)}
              className={`
                flex items-center gap-2 px-4 py-3 border-b-3 transition-all font-bold
                ${activeTab === tab.id ?
                  'border-purple-500 text-white bg-purple-600/40 shadow-lg' :
                  'border-transparent text-gray-200 hover:text-white hover:bg-purple-600/20 bg-gray-800/50'}
              `}
            >
              <tab.icon className={`w-4 h-4 ${activeTab === tab.id ? 'text-white' : 'text-gray-300'}`} />
              <span className="text-sm">{tab.label}</span>
            </button>
          ))}
        </div>
      </div>

      {/* Main Content Area */}
      <div className="px-6 py-6">
        {activeTab === 'experiments' && <ExperimentsTab currentStep={currentStep} loading={loading} progress={progress} handleStepAction={handleStepAction} cohortData={cohortData} validationResults={validationResults} />}
        {activeTab === 'intake' && <IntakeTab />}
        {activeTab === 'patterns' && <PatternsTab />}
        {activeTab === 'fingerprints' && <FingerprintsTab />}
        {activeTab === 'predict' && <PredictTab />}
      </div>
    </div>
  );
}

