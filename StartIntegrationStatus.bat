@echo off
setlocal ENABLEDELAYEDEXPANSION
REM Start Next.js dev server and open the integration status page
cd /d %~dp0
start "next-dev" cmd /c "cd /d %~dp0 && npm run dev"
REM Wait a few seconds for the server to boot
timeout /t 10 >nul
start "browser" http://localhost:3000/api/admin/integration/status
echo If the page did not open, wait a few more seconds and refresh your browser.
pause














































































































































