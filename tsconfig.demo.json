{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true,
    "allowJs": false,
    "types": ["react", "react-dom", "node"],
    "plugins": []
  },
  "include": [
    "src/components/templateMiniUI/**/*",
    "src/app/template-mini-ui-demo/page.tsx",
    "src/lib/supabase-client.ts",
    "src/lib/env.ts",
    "src/components/ui/dialog.tsx",
    "src/components/ui/button.tsx"
  ],
  "exclude": [
    "node_modules",
    "src/components/templateMiniUI/__tests__/**/*",
    "src/components/ui/**/__tests__/**/*",
    "src/components/ui/**/*.test.ts*",
    "src/components/ui/AnimatedContainer.tsx",
    "src/components/ui/CosmicDashboardCard.tsx",
    "src/components/ui/InteractiveElement.tsx",
    "src/components/ui/morphing-dialog.tsx",
    "src/components/ui/SkeletonLoader.tsx",
    "src/components/ui/theme-provider.tsx",
    "src/components/ui/TopBanner.tsx",
    "src/lib/services/optimization/**/*",
    "src/lib/services/featureDecomposer*",
    "src/lib/services/viral-prediction/**/*",
    "src/lib/services/apify*",
    "src/app/api/**/*",
    "src/pages/**/*"
  ]
}


